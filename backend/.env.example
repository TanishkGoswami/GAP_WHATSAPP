# Core backend
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Exactly 32 ASCII characters. Never commit the real value.
TOKEN_ENCRYPTION_KEY=
PUBLIC_BASE_URL=https://api.example.com
CORS_ORIGINS=https://app.example.com

# Meta WhatsApp Cloud API
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
META_REDIRECT_URI=https://app.example.com/wa-callback
META_GRAPH_VERSION=v21.0
WA_VERIFY_TOKEN=
WEBHOOK_DEBUG=false

# Durable broadcast queue
BROADCAST_QUEUE_ENABLED=false
BROADCAST_GLOBAL_PAUSED=false
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
BROADCAST_MAX_RECIPIENTS=10000
BROADCAST_JSON_LIMIT=5mb
BROADCAST_DISPATCH_WINDOW=100
BROADCAST_RATE_PER_SECOND=10
BROADCAST_PREPARE_CONCURRENCY=2
BROADCAST_SEND_CONCURRENCY=20
BROADCAST_STALE_MINUTES=15
