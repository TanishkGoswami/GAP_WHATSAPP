{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist"
    },
    "include": [
        "server.ts",
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "extract_agents.ts",
        "temp_flow.ts",
        "extract_flow_engine.ts"
    ]
}
